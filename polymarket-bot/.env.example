# ── Polymarket credentials ──────────────────────────────────────────────────
# Get your API keys at: https://docs.polymarket.com/#api-keys
# Private key from your wallet (used for signing orders in live mode)
POLYMARKET_PK=

# L2 API credentials (generated from the Polymarket CLOB interface)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ── Optional overrides ─────────────────────────────────────────────────────
# DASHBOARD_PORT=8080
# MAX_POSITION_SIZE=1.0
# INITIAL_PAPER_BANKROLL=100.0
