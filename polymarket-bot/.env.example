# ── Polymarket credentials ──────────────────────────────────────────────────
# IMPORTANTE: POLYMARKET_PK deve ser definida como variável de AMBIENTE DO SISTEMA
# (não aqui no .env). Nunca é logada ou printada.
# Windows: setx POLYMARKET_PK "0xsuachaveprivada" /M
# Linux:   export POLYMARKET_PK="0xsuachaveprivada"

# L2 API credentials (geradas na interface CLOB do Polymarket)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ── Segurança do Dashboard ─────────────────────────────────────────────────
# Senha para ativar o modo live pelo dashboard (padrão: CONFIRMAR)
LIVE_MODE_PASSWORD=CONFIRMAR

# ── Telegram (opcional) ────────────────────────────────────────────────────
# Crie um bot em https://t.me/BotFather e obtenha o token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Valor mínimo de trade para gerar alerta (USDC)
TELEGRAM_ALERT_MIN_TRADE_SIZE=5.0

# ── Risk Management ────────────────────────────────────────────────────────
# Kill switch: parar tudo quando banca cair abaixo deste valor (USDC)
MINIMUM_BALANCE_USDC=10.0

# ── Copy Trading (opcional) ────────────────────────────────────────────────
# Endereços de carteiras para monitorar (separados por vírgula)
# COPY_TRADE_WALLETS=0xABC...,0xDEF...
COPY_TRADE_WALLETS=

# ── Dashboard ─────────────────────────────────────────────────────────────
# DASHBOARD_PORT=8080
